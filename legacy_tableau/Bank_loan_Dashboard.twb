      <aliases enabled='yes' />
      <column caption='Total Loan Applications ' datatype='integer' name='[Calculation_1709397555083751424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id])' />
      </column>
      <column caption='MTD Total Loan Application' datatype='integer' name='[Calculation_1709397555086385153]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(if &#13;&#10;MONTH([issue_date])=[Parameters].[Parameter 2]&#13;&#10;THEN [id]&#13;&#10;end )' />
      </column>
      <column caption='MoM total loan application ' datatype='real' name='[Calculation_1709397555087425539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1709397555086385153]-[MTD Total Loan Application (copy)_1709397555087204354])&#13;&#10;/&#13;&#10;[MTD Total Loan Application (copy)_1709397555087204354]' />
      </column>
      <column caption='Total Amount recieved' datatype='integer' name='[Calculation_1709397555091423240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_payment])' />
      </column>
      <column caption='Average Interest Rate' datatype='real' name='[Calculation_1709397555092905996]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([int_rate])' />
      </column>
      <column caption='AVG DTI' datatype='real' name='[Calculation_1709397555094544400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([dti])' />
      </column>
      <column caption='Good Loan %' datatype='real' name='[Calculation_1709397555124310038]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT( IF  [Good vs Bad Loan]=&apos;Good Loan&apos; THEN [id] END)&#13;&#10;/&#13;&#10;COUNT([id])' />
      </column>
      <column caption='Good Loan Application ' datatype='integer' name='[Calculation_1709397555126034455]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(if [Good vs Bad Loan]=&apos;Good Loan&apos; THEN [id] END)' />
      </column>
      <column caption='Dyanmic measure' datatype='integer' name='[Calculation_1709397555144003616]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1]=&apos;Total Loan Applications&apos; THEN [Calculation_1709397555083751424]&#13;&#10;ELSEIF [Parameters].[Parameter 1]=&apos;Total Funded Amount&apos; then [Total Loan Applications  (copy)_1709397555087925252]&#13;&#10;ELSEIF [Parameters].[Parameter 1]=&apos;Total Amount Received&apos; THEN [Calculation_1709397555091423240]&#13;&#10;END' />
      </column>
      <column caption='total app' datatype='integer' name='[Calculation_645985100562624512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(id)' />
      </column>
      <column caption='Bad Loan % ' datatype='real' name='[Good Loan % (copy)_1709397555130073116]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT( IF  [Good vs Bad Loan]=&apos;Bad Loan&apos; THEN [id] END)&#13;&#10;/&#13;&#10;COUNT([id])' />
      </column>
      <column caption='Bad Loan Amount Received ' datatype='integer' name='[Good Loan Amount Received (copy)_1709397555131174943]' role='measure' type='quantitative'>
